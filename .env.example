# Copy this file to .env for local development (it is gitignored).
# On Railway, set these as service variables instead.

# Password you type to log in (you are the only user).
APP_PASSWORD=your_password_here

# Random string used to sign your login cookie. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=generate_with__python_-c_"import_secrets;_print(secrets.token_hex(32))"

# OPTIONAL: set this to enable AI feedback on your sentence translations.
# Leave blank to disable. Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Where the SQLite database lives.
# Local: ./data is fine. On Railway: set to /data and mount a Volume there
# so your progress survives redeploys.
DATA_DIR=./data

# Where your lesson YAML files live. Usually leave as-is.
CONTENT_DIR=./content
